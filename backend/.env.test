# Test Environment
NODE_ENV=test
APP_NAME=SchoolProfile-Test
APP_PORT=5001
APP_URL=http://localhost:5000

# Database (mock/test)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=school_profile_test
DB_CONNECTION_LIMIT=5

# JWT
JWT_SECRET=test-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# Upload
UPLOAD_PATH=./uploads/test
MAX_FILE_SIZE=2097152
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
ALLOWED_DOC_TYPES=pdf,doc,docx,xls,xlsx

# CORS
CORS_ORIGIN=https://studious-space-bassoon-4q5gg9w5x9phg47-5173.app.github.dev

# Logging
LOG_LEVEL=error
LOG_DIR=./logs/test
